# =============================================================
# .gitignore for Python + Bash project
# =============================================================

# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# mypy / pyright type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# Jupyter Notebooks
.ipynb_checkpoints/

# ---------------------------
# Environment / secrets
# ---------------------------
.env
.env.*
*.env
secrets.txt

# ---------------------------
# Bash / Shell
# ---------------------------
*.sh.swp

# ---------------------------
# Generated reports (keep dir, ignore output files)
# ---------------------------
reports/disk_report_*.txt
reports/disk_report_latest.txt
audit_report.txt

# ---------------------------
# OS / Editor artifacts
# ---------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ---------------------------
# Logs
# ---------------------------
*.log
logs/
